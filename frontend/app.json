{
  "expo": {
    "name": "frontend",
    "jsEngine": "hermes",
    "slug": "frontend",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "frontend",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.frontend"
    },
    "web": {
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-splash-screen",
      [
        "expo-build-properties",
        {
          "android": {
            "kotlinVersion": "2.0.21",
            "packagingOptions": {
              "pickFirst": [
                "**/libc++_shared.so"
              ]
            }
          }
        }
      ],
      "@lovesworking/watermelondb-expo-plugin-sdk-52-plus",
      [
      "react-native-vision-camera",
      {
        "cameraPermissionText": "pic2recipe needs access to your Camera."
      }
    ]    
  ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
